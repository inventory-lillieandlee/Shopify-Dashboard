# Lillie & Lee — Inventory System · environment template
# Copy to .env.local (gitignored) and fill in. NEVER commit real values.
# Only NEXT_PUBLIC_* vars reach the browser; everything else is server-only.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only — bypasses RLS. Used ONLY by the cron route (projections upsert +
# alert_log insert). NEVER expose as NEXT_PUBLIC, never import client-side.
SUPABASE_SERVICE_ROLE_KEY=

# ── Shopify (client-credentials grant; used by the demand + inventory cron) ──
SHOPIFY_STORE=                  # e.g. your-store.myshopify.com
SHOPIFY_API_KEY=                # custom-app client_id (public identifier)
SHOPIFY_API_SECRET=             # custom-app secret (server-only) — shpss_…
SHOPIFY_API_VERSION=2026-04
SHOPIFY_ADMIN_TOKEN=            # optional shpat_ token (unused with client-credentials)

# ── ReCharge (Phase 2) ──────────────────────────────────────────────────────
RECHARGE_API_TOKEN=
RECHARGE_API_VERSION=2021-11

# ── Alerts — Resend (Phase A.2) ─────────────────────────────────────────────
RESEND_API_KEY=                 # server-only secret
ALERT_FROM_EMAIL=               # Resend-verified sender
ALERT_TIMEZONE=America/New_York # IANA tz for date rendering in alert emails
ALERT_DASHBOARD_URL=            # base URL for SKU links in emails, e.g. https://...
# NOTE: recipients are now managed in the DB (alert_recipients), editable in
# Settings → Alerts (admin-only). ALERT_TO_EMAILS / ALERT_MIN_LEVEL are no longer used.

# ── Cron protection ─────────────────────────────────────────────────────────
# Bearer token Vercel Cron sends automatically; the cron route rejects requests
# without it. Set the same value here and in Vercel project env.
CRON_SECRET=

# ── Auth (Phase E — DORMANT by default) ─────────────────────────────────────
# "true" turns on invite-only gating (middleware redirects unauthenticated users
# to /login). Anything else = dormant = public dashboard (today's behavior). Flip
# to "true" ONLY as the go-live step in docs/phase-e/go-live-runbook.md.
AUTH_ENABLED=false

# ── App ─────────────────────────────────────────────────────────────────────
APP_TIMEZONE=America/New_York
